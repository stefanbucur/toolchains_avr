        "2026-06-18/clippy-nightly-aarch64-unknown-linux-gnu.tar.xz": "c5f2a8592e4e14eab74727116e576afd99bec6989cb4e44640199f2d7936ee18",
        "2026-06-18/clippy-nightly-x86_64-unknown-linux-gnu.tar.xz": "2cc0142a564371bd3a0b65318455801641243d2dc891e37306857b1ce6ff452f",
        "2026-06-18/llvm-tools-nightly-aarch64-apple-darwin.tar.xz": "aef00b81eb2e96df663020ef03089e1faa6e0099c07d8fdf512c16c2948beadb",
        "2026-06-18/llvm-tools-nightly-aarch64-unknown-linux-gnu.tar.xz": "111a3f9ef5656e9fb8ea1f7a3567a12fea8a9e5d0ff5f715ed280b4c6f721807",
        "2026-06-18/llvm-tools-nightly-x86_64-unknown-linux-gnu.tar.xz": "2125a161da4e18f0c00fc6bb4f4b28729f6c8e33c6691973e29c99a6dc06f036",
