        "2026-06-18/rust-std-nightly-x86_64-unknown-linux-gnu.tar.xz": "2684fb3c942499172d36de43baaa0facf055827de5de6d25497be0787950bd28",
        "2026-06-18/rustc-nightly-aarch64-apple-darwin.tar.xz": "9efd84a1fe2f74611c9fc4725823d6702bb6080077cb8be8a18d5e8b8c11c580",
