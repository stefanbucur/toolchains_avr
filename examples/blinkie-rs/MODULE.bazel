module(
    name = "blinkie_rs",
    version = "0.0.0",
)

bazel_dep(name = "rules_cc", version = "0.2.19")

# rules_rust listed before toolchains_avr intentionally — the rust.toolchain
# target_settings below ensures rules_rust's host toolchain only fires outside
# of AVR exec configs, so ordering no longer causes a proc-macro ABI mismatch.
bazel_dep(name = "rules_rust", version = "0.70.0")
bazel_dep(name = "toolchains_avr", version = "0.0.0", repo_name = "avr")
local_path_override(
    module_name = "toolchains_avr",
    path = "../..",
)

avr = use_extension("@avr//avr:extensions.bzl", "avr")
avr.cc_toolchain(
    distro = "avr-toolchain-gcc15.2.0-libc2.3.1-binutils2.46",
)
avr.rust_toolchain(
    edition = "2024",
    nightly_stamp = "2026-06-18",
    src_sha256 = "f6eaf06ff6eeff09750219bd29ea9ad96139d46a884a4179d3ac3fe23bd84e8e",
    tools_sha256s = {
        "2026-06-18/cargo-nightly-aarch64-apple-darwin.tar.xz": "3d42aaa1a6324521b0c0a962a09cf9cf50fa82b33b63da30331e911e67f5be9b",
        "2026-06-18/cargo-nightly-aarch64-unknown-linux-gnu.tar.xz": "b07388440d1074971b5a6017a09bbe48fac729db2d0bd09aa732ddd8e594e015",
        "2026-06-18/cargo-nightly-x86_64-unknown-linux-gnu.tar.xz": "8a28c8bf2bc040bdd708b3fb498e602d13b266ffc2db430429aa22074e629298",
